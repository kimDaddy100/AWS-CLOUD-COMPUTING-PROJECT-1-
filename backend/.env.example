# Copy this file to .env and fill in your values
# For local development use the values below
# For AWS, these are set in Elastic Beanstalk environment config

PORT=3000

# Local PostgreSQL (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskmanager
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Set this to your CloudFront URL after deploying the frontend
FRONTEND_URL=http://localhost:5173
